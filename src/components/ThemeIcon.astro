---
import { Moon, Sun } from "@lucide/astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<button
  aria-label="Toggle theme"
  data-theme-toggle
  class:list={[className, "cursor-pointer flex items-center justify-center"]}
>
  <Sun class="hidden dark:block text-white hover:text-blue-500 w-full h-full" />
  <Moon
    class="block dark:hidden text-black hover:text-blue-500 w-full h-full"
  />
</button>

<script>
  document.addEventListener("astro:page-load", () => {
    const themeToggles = document.querySelectorAll("[data-theme-toggle]");

    const handleToggleClick = () => {
      const element = document.documentElement;
      element.classList.toggle("dark");

      const isDark = element.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    };

    themeToggles!.forEach((element) => {
      element.addEventListener("click", handleToggleClick);
    });
  });
</script>
