---
import { Moon, Sun } from "@lucide/astro";
---

<button
  id="themeToggle"
  aria-label="Toggle theme"
  class="cursor-pointer w-10 h-10 flex items-center justify-center"
>
  <Sun class="hidden dark:block text-white hover:text-blue-500" />
  <Moon class="block dark:hidden text-black hover:text-blue-500" />
</button>

<script>
  document.addEventListener("astro:page-load", () => {
    const themeToggle = document.getElementById("themeToggle");

    const handleToggleClick = () => {
      const element = document.documentElement;
      element.classList.toggle("dark");

      const isDark = element.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    };

    themeToggle?.addEventListener("click", handleToggleClick);
  });
</script>
