---
import { FileDown } from "@lucide/astro";
import { navItems } from "src/lib/constants";

import { Sidebar } from "src/components/Sidebar";
import LanguageMenu from "src/components/LanguageMenu.astro";
import ThemeIcon from "src/components/ThemeIcon.astro";

import { useTranslations } from "src/lib/i18n/utils";
import type { Language } from "src/types";

const currentLanguage: Language = (Astro.currentLocale || "en") as Language;
const t = useTranslations(currentLanguage);
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-20 header-scroll-effect"
>
  <nav
    class="flex py-2 md:py-4 px-4 justify-between items-center gap-4 font-mono w-full md:pr-8 md:before:content-[''] md:before:border-b md:before:border-border-primary md:before:w-full hide-line-effect"
  >
    <ul class="hidden md:flex justify-end items-center gap-6 lg:gap-10 lg:pl-8">
      {
        navItems.map((item) => (
          <li>
            <a
              href={`#${item.id}`}
              class="text-text-primary hover:text-blue-500 hover:border-b-4 hover:border-blue-500 pb-2"
            >
              {t(item.labelKey)}
            </a>
          </li>
        ))
      }
    </ul>

    <span class="hidden md:block border-l h-6 border-border-primary"></span>

    <div
      class="hidden md:flex justify-end items-center gap-4 py-4 text-text-primary"
    >
      <ThemeIcon class="hidden md:block size-6" />
      <LanguageMenu />
    </div>

    <a
      href="/files/resume-12-25.pdf"
      download="Marcelo-Oroquieta-CV.pdf"
      data-track-resume
      class="bg-slate-700 dark:bg-slate-600 text-white px-5 py-2.5 rounded-full flex gap-2 items-center shrink-0 hover:bg-blue-500 cursor-pointer active:transform active:scale-95"
    >
      <FileDown class="w-5 h-5" />
      {t("nav.button.downloadcv")}
    </a>

    <div class="flex items-center gap-4">
      <ThemeIcon
        class="md:hidden hover:text-blue-500 cursor-pointer stroke-2 size-8"
      />
      <Sidebar currentLanguage={currentLanguage} client:visible />
    </div>
  </nav>
</header>

<script>
  import { trackEvent } from "src/lib/utils/analytics";

  document.addEventListener("astro:page-load", () => {
    const resumeButtons = document.querySelectorAll("[data-track-resume]");

    resumeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        trackEvent("download_resume", {
          file_name: "Marcelo-Oroquieta-CV.pdf",
        });
      });
    });
  });
</script>
