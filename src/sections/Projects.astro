---
import { Image } from "astro:assets";
import {
  Speech,
  Shirt,
  SquareTerminal,
  ArrowUpRight,
} from "@lucide/astro";
import { useTranslations } from "src/lib/i18n/utils";
import type { Language } from "src/types";

const currentLanguage: Language = (Astro.currentLocale || "en") as Language;
const t = useTranslations(currentLanguage);

const projects = [
  {
    appNameKey: "projects.prepwise.appName",
    titleKey: "projects.prepwise.title",
    dateKey: "projects.prepwise.date",
    projectIcon: Speech,
    image: "/images/project-interview.webp",
    descriptionKey: "projects.prepwise.description",
    technologies: [
      "Next.js",
      "React.js",
      "TypeScript",
      "Firebase",
      "Tailwind CSS",
      "Zod",
      "AI SDK",
      "VAPI AI",
    ],
    link: "https://interviewer-ai-green.vercel.app/",
  },
  {
    appNameKey: "projects.sapphire.appName",
    titleKey: "projects.sapphire.title",
    dateKey: "projects.sapphire.date",
    projectIcon: Shirt,
    image: "/images/project-ecommerce.webp",
    descriptionKey: "projects.sapphire.description",
    technologies: [
      "Next.js",
      "React.js",
      "TypeScript",
      "Prisma ORM",
      "NeonDB",
      "Stripe",
      "PayPal",
      "Next Auth",
      "Auth.js",
      "Shadcn UI",
      "Tailwind CSS",
      "Framer Motion",
      "Recharts",
      "Zod",
      "Resend",
      "UploadThing",
    ],
    link: "https://ecommerce-bay-nine-22.vercel.app/",
  },
  {
    appNameKey: "projects.promptverse.appName",
    titleKey: "projects.promptverse.title",
    dateKey: "projects.promptverse.date",
    projectIcon: SquareTerminal,
    image: "/images/project-prompt-sharing.webp",
    descriptionKey: "projects.promptverse.description",
    technologies: [
      "Next.js",
      "React.js",
      "TypeScript",
      "MongoDB",
      "Mongoose",
      "Next Auth",
    ],
    link: "https://share-prompts-henna.vercel.app/",
  },
];
---

<section id="projects" class="w-full flex justify-center bg-slate-200 py-18">
  <div
    class="w-full flex flex-col items-center max-w-5xl px-4 md:px-8 lg:px-0 gap-16"
  >
    <h2 class="text-5xl font-bold text-slate-600">{t("projects.title")}</h2>
    <div class="w-full flex flex-col items-center justify-center gap-8">
      {
        projects.map((project) => {
          const Icon = project.projectIcon;
          return (
            <div class="w-full grid grid-cols-1 lg:grid-cols-5 bg-white p-5 gap-5 rounded-xl shadow-sm hover:scale-102 hover:shadow-xl transition-all">
              <Image
                src={project.image}
                width={380}
                height={200}
                alt={t(project.titleKey)}
                class="w-full h-auto md:h-full shadow-sm aspect-video object-cover object-top col-span-1 lg:col-span-2 rounded-lg"
              />
              <div class="flex flex-col gap-1 font-mono lg:col-span-3">
                <div class="flex justify-between items-center">
                  <div class="flex justify-start items-center gap-2 mb-1 text-slate-500 text-sm tracking-wider">
                    <div class="w-8 h-8 flex justify-center items-center bg-blue-100 rounded-full">
                      <Icon class="w-4 h-4 text-blue-700" />
                    </div>
                    {t(project.appNameKey)}
                  </div>
                  <p class="text-slate-400 text-sm tracking-wider">
                    {t(project.dateKey)}
                  </p>
                </div>
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <h3 class="flex mb-2 gap-1 items-center text-xl font-semibold text-slate-900 group hover:text-blue-600 hover:underline hover:underline-offset-5">
                    {t(project.titleKey)}{" "}
                    <ArrowUpRight class="group-hover:scale-125 transition-all w-5 h-5" />
                  </h3>
                </a>
                <p class="text-slate-500 font-light mb-2">
                  {t(project.descriptionKey)}
                </p>
                <div class="flex flex-wrap justify-start items-center gap-2">
                  {project.technologies.map((tech) => (
                    <span class="px-2 py-1 bg-slate-100 text-slate-600 text-sm rounded-full">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
    <!-- <button
      class="bg-slate-700 text-white px-5 font-mono py-3 rounded-full flex gap-2 items-center shrink-0 hover:bg-blue-500 cursor-pointer active:transform active:scale-95"
    >
      <CirclePlus class="w-5 h-5" />
      Load More
    </button> -->
  </div>
</section>
