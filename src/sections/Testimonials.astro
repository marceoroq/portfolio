---
import { useTranslations } from "src/lib/i18n/utils";
import TestimonialCarousel from "src/components/TestimonialsCarousel.tsx";
import type { Language, Testimonial } from "src/types";

const currentLanguage: Language = (Astro.currentLocale || "en") as Language;
const t = useTranslations(currentLanguage);

const testimonials: Testimonial[] = [
  {
    quote: t("testimonials.items.0.quote"),
    name: "Ignacio Femenia",
    title: t("testimonials.items.0.title"),
    company: "Accenture",
    avatarSrc: "/images/testimonials-ignacio-avatar.webp",
    companyLogo: "/images/accenture-logo.webp",
  },
  {
    quote: t("testimonials.items.1.quote"),
    name: "Juan Enrrique Barranco Sanz",
    title: t("testimonials.items.1.title"),
    company: "Gaucho Sec",
    avatarSrc: "/images/testimonials-juan-avatar.webp",
    companyLogo: "/images/gauchosec-logo.webp",
  },
  {
    quote: t("testimonials.items.2.quote"),
    name: "Yoel Lapscher",
    title: "CTO",
    company: "TiendaPago",
    avatarSrc: "/images/testimonials-yoel-avatar.webp",
    companyLogo: "/images/tiendapago-logo.webp",
  },
];
---

<section id="testimonials" class="w-full flex justify-center bg-white dark:bg-bg-primary py-12 md:py-18">
  <div class="w-full flex flex-col items-center max-w-5xl px-4 md:px-8 lg:px-0 gap-6 md:gap-12">
    <h2 class="text-4xl md:text-5xl font-bold text-slate-900 tracking-tight text-center dark:text-text-primary">
      {t("testimonials.title")}
    </h2>
    <TestimonialCarousel testimonials={testimonials} currentLanguage={currentLanguage} client:visible />
  </div>
</section>
